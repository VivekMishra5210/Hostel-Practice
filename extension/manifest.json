{
  "manifest_version": 3,

  "name": "IIITN Hostel Autofill",
  "version": "1.0",

  "description": "Fast hostel form autofill tool",

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],

      "js": [
        "content.js"
      ]
    }
  ]
}
